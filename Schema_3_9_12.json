{
  "openapi": "3.1.0",
  "info": {
    "title": "Intervals.icu API + Unified Reporting Framework (Hybrid Dual-Mode Schema)",
    "version": "3.9.13-dual-mode",
    "description": "Splits lightweight (Tier-0) and full (Tier-1) fetches into separate operations to prevent connector deduplication."
  },
  "servers": [
    { "url": "https://intervalsicugptcoach.clive-a5a.workers.dev" }
  ],
  "paths": {
    "/athlete/0/activities_t0light": {
      "get": {
        "summary": "List activities (Tier-0 lightweight, 28-day reduced fieldset)",
        "operationId": "listActivitiesLight",
        "parameters": [
          { "name": "oldest", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "newest", "in": "query", "schema": { "type": "string", "format": "date" } },
          {
            "name": "fields",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated field list for lightweight mode"
          }
        ],
        "responses": {
          "200": {
            "description": "Lightweight 28-day dataset",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } }
              }
            }
          }
        }
      }
    },

    "/athlete/0/activities": {
      "get": {
        "summary": "List activities (Tier-0/Tier-1 full, 7-day detailed fields)",
        "operationId": "listActivitiesFull",
        "parameters": [
          { "name": "oldest", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "newest", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer" } },
          { "name": "chunk", "in": "query", "schema": { "type": "string" } },
          { "name": "auto", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Full activity dataset (≤7 days)",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } }
              }
            }
          }
        }
      }
    },

    "/athlete/0/wellness": {
      "get": {
        "summary": "List wellness data (≤7 days, JSON)",
        "operationId": "listWellness",
        "parameters": [
          { "name": "oldest", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "newest", "in": "query", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": {
            "description": "Wellness dataset",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Wellness" } }
              }
            }
          }
        }
      }
    },

    "/athlete/0/profile": {
      "get": {
        "summary": "Fetch athlete profile",
        "operationId": "getAthleteProfile",
        "responses": {
          "200": {
            "description": "Athlete profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "athlete": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "name": { "type": "string" },
                        "timezone": { "type": ["string", "null"] },
                        "country": { "type": ["string", "null"] },
                        "sex": { "type": ["string", "null"] }
                      },
                      "required": ["id", "name"]
                    }
                  },
                  "required": ["athlete"]
                }
              }
            }
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "Activity": {
        "type": "object",
        "required": ["id", "start_date_local", "type", "distance", "moving_time"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": ["string", "null"] },
          "type": { "type": "string" },
          "sport_type": { "type": ["string", "null"] },
          "start_date_local": { "type": "string", "format": "date-time" },
          "distance": { "type": "number" },
          "moving_time": { "type": "number" },
          "icu_training_load": { "type": ["number", "null"] },
          "average_heartrate": { "type": ["number", "null"] },
          "IF": { "type": ["number", "null"] },
          "VO2MaxGarmin": { "type": ["number", "null"] }
        }
      },
      "Wellness": {
        "type": "object",
        "required": ["date"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "ctl": { "type": ["number", "null"] },
          "atl": { "type": ["number", "null"] },
          "form": { "type": ["number", "null"] },
          "vo2max": { "type": ["number", "null"] },
          "restingHr": { "type": ["number", "null"] },
          "fatigue": { "type": ["number", "null"] }
        }
      }
    },
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://intervals.icu/oauth/authorize",
            "tokenUrl": "https://intervals.icu/api/oauth/token",
            "scopes": {
              "ACTIVITY:READ": "Read activities",
              "WELLNESS:READ": "Read wellness data",
              "SETTINGS:READ": "Read athlete profile"
            }
          }
        }
      }
    }
  },

  "security": [{ "OAuth2": ["ACTIVITY:READ", "WELLNESS:READ", "SETTINGS:READ"] }],
  "x-intents": [
    {
      "trigger": [
        "tier0",
        "tier0 pre-audit",
        "run tier0 fetch",
        "run lightweight fetch",
        "prepare 28-day snapshot",
        "fetch 28-day summary",
        "tier0 start"
      ],
      "action": "run_lightweight_audit_pipeline"
    },
    {
      "trigger": [
        "tier1",
        "fetch activities",
        "run full fetch",
        "tier1 analysis",
        "run 7-day report",
        "fetch full dataset"
      ],
      "action": "run_full_audit_pipeline"
    },
    {
      "trigger": [
        "weekly report",
        "run weekly report"
      ],
      "action": "run_report_orchestrated"
    }
  ],
  "x-actions": {
    "run_report_orchestrated": {
      "type": "python",
      "entrypoint": "run_report",
      "args": {
        "reportType": "weekly",
        "autoCommit": true,
        "suppressPrompts": true
      }
    },
    "run_full_audit_pipeline": {
      "type": "chain",
      "steps": [
        "getAthleteProfile",
        "listActivitiesFull",
        "listWellness"
      ]
    },
    "run_lightweight_audit_pipeline": {
      "type": "chain",
      "steps": [
        "getAthleteProfile",
        "listActivitiesLight",
        "listWellness"
      ]
    }
  }
}

