{
  "deploy": {
    "base": {
      "image": "ghcr.io/railwayapp/railpack-runtime:latest"
    },
    "inputs": [
      {
        "include": [
          "/**/*"
        ],
        "step": "build"
      }
    ],
    "startCommand": "uvicorn app:app --host 0.0.0.0 --port ${PORT:-8000}"
  },
  "build": {
    "steps": [
      {
        "cmd": "pip install -r requirements.txt"
      }
    ]
  }
}
