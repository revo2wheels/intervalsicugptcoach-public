sex': None, 'bio': None, 'website': None, 'email': None}, 'from_id': None}, {'id': 801886, 'athlete_id': '1914741', 'type': 'ACTIVITY_FIELD', 'visibility': 'PRIVATE', 'name': 'Activity Power Meter', 'description': 'Returns the Manufacturer, Product and Serial number for the power meter', 'image': None, 'content': {'max': None, 'min': None, 'code': 'ActivityPowerMeter', 'icon': None, 'link': None, 'type': 'text', 'color': '#333333', 'gauge': True, 'total': None, 'units': None, 'inline': True, 'prefix': None, 'script': '{\n  let power_meter\n  for (let di of icu.fit.device_info) {\n    if (di.device_type?.value !== 11 /* Power Meter */)     continue\n    let manufacturer = di.manufacturer?.valueName\n   /* if (!manufacturer) continue */\n    let serial = di.serial_number?.valueName\n    /*if (!serial) continue */\n    let product = di.product?.valueName\n    /*if (!product) continue*/\n    power_meter = manufacturer + (product ? " " + product : "") + (serial ? " " + serial : "")\n  }\n  power_meter\n}', 'suffix': None, 'average': None, 'convert': '', 'example': 42, 'options': None, 'aggregate': 'SUM', 'text_wrap': None, 'pace_units': None, 'text_align': None, 'number_format': '.1f', 'fit_session_field': None, 'processes_fit_messages': True, 'name': 'Activity Power Meter'}, 'usage_count': 0, 'index': 6, 'hide_script': False, 'hidden_by_id': None, 'updated': '2025-10-23T10:58:32.147+00:00', 'from_athlete': {'id': '5372910', 'name': 'John Peters (endura.fit)', 'profile_medium': 'https://storage.googleapis.com/intervals-icu-images/profile_pics/05c108bd-973d-4f21-9f42-3d7799e8cf13', 'city': 'Lickfold', 'state': 'England', 'country': 'United Kingdom', 'timezone': 'Europe/London', 'sex': 'M', 'bio': None, 'website': 'https://www.bluecattechnical.co.uk', 'email': None}, 'from_id': 177376}, {'id': 11481, 'athlete_id': '1914741', 'type': 'FITNESS_CHART', 'visibility': 'PRIVATE', 'name': 'W', 'description': None, 'image': None, 'content': {'id': '1dff32b6', 'name': 'W', 'plots':