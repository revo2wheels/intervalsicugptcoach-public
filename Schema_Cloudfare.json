{
  "openapi": "3.1.0",
  "info": {
    "title": "Intervals.icu Training Coach Proxy",
    "version": "5.2.0",
    "description": "Cloudflare proxy for URF reports. ChatGPT never sees raw activities/wellness."
  },

  "servers": [
    { "url": "https://intervalsicugptcoach.clive-a5a.workers.dev" }
  ],

  "paths": {
    "/run_weekly": {
      "get": {
        "summary": "Generate a weekly URF report (7-day)",
        "operationId": "runWeeklyReport",
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["semantic", "markdown", "json"],
              "default": "semantic"
            },
            "description": "Select output format. Default = semantic."
          }
        ],
        "responses": {
          "200": {
            "description": "Weekly URF report output (markdown + semantic graph)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReportResponse" }
              }
            }
          }
        }
      }
    },

    "/run_season": {
      "get": {
        "summary": "Generate a season URF report (90-day block)",
        "operationId": "runSeasonReport",
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["semantic", "markdown", "json"],
              "default": "semantic"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Season URF report output",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReportResponse" }
              }
            }
          }
        }
      }
    },

    "/run_wellness": {
      "get": {
        "summary": "Generate a 42-day wellness URF report",
        "operationId": "runWellnessReport",
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["semantic", "markdown", "json"],
              "default": "semantic"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Wellness URF report output",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReportResponse" }
              }
            }
          }
        }
      }
    },

    "/run_summary": {
      "get": {
        "summary": "Generate a URF high-level summary",
        "operationId": "runSummaryReport",
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["semantic", "markdown", "json"],
              "default": "semantic"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Summary URF output (profile + key stats)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReportResponse" }
              }
            }
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "ReportResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "report_type": { "type": "string" },
          "markdown": { "type": ["string", "null"] },
          "semantic_graph": { "type": ["object", "null"] },
          "logs": { "type": ["string", "null"] }
        }
      }
    }
  },

  "x-intents": [
    {
      "trigger": [
        "weekly report",
        "run weekly report",
        "generate weekly report",
        "7 day report",
        "7-day report",
        "past week report"
      ],
      "action": "runWeeklyReport",
      "x-intent": {
        "x-intent": "weekly",
        "strict": true
      }
    },
    {
      "trigger": [
        "season report",
        "90 day report",
        "block report",
        "training block report",
        "run season report"
      ],
      "action": "runSeasonReport",
      "x-intent": {
        "x-intent": "season",
        "strict": true
      }
    },
    {
      "trigger": [
        "wellness report",
        "42 day wellness",
        "recovery report",
        "run wellness report"
      ],
      "action": "runWellnessReport",
      "x-intent": {
        "x-intent": "wellness",
        "strict": true
      }
    },
    {
      "trigger": [
        "summary report",
        "overview report",
        "high level summary",
        "run summary"
      ],
      "action": "runSummaryReport",
      "x-intent": {
        "x-intent": "summary",
        "strict": true
      }
    }
  ],

  "x-actions": {
    "runWeeklyReport": {
      "type": "operation",
      "operationId": "runWeeklyReport"
    },
    "runSeasonReport": {
      "type": "operation",
      "operationId": "runSeasonReport"
    },
    "runWellnessReport": {
      "type": "operation",
      "operationId": "runWellnessReport"
    },
    "runSummaryReport": {
      "type": "operation",
      "operationId": "runSummaryReport"
    }
  }
}
