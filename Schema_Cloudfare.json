{
  "openapi": "3.1.0",
  "info": {
    "title": "Intervals.icu Training Coach Proxy",
    "version": "5.0.0",
    "description": "Single-call proxy. ChatGPT never receives raw activity/wellness data."
  },

  "servers": [
    { "url": "https://intervalsicugptcoach.clive-a5a.workers.dev" }
  ],

  "paths": {
    "/run_weekly": {
      "post": {
        "summary": "Request a weekly URF report",
        "operationId": "runWeeklyReport",
        "responses": {
          "200": {
            "description": "Final URF rendered report (semantic + markdown)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReportResponse" }
              }
            }
          }
        }
      }
    },

    "/run_season": {
      "post": {
        "summary": "Request a 90-day URF season/block report",
        "operationId": "runSeasonReport",
        "responses": {
          "200": {
            "description": "Final URF rendered report",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReportResponse" }
              }
            }
          }
        }
      }
    },

    "/run_wellness": {
      "post": {
        "summary": "Request a 42-day wellness URF report",
        "operationId": "runWellnessReport",
        "responses": {
          "200": {
            "description": "Final URF rendered report",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReportResponse" }
              }
            }
          }
        }
      }
    },

    "/run_summary": {
      "post": {
        "summary": "Request a high-level summary URF report",
        "operationId": "runSummaryReport",
        "responses": {
          "200": {
            "description": "Final URF rendered report",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReportResponse" }
              }
            }
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "ReportResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "report_type": { "type": "string" },
          "markdown": { "type": ["string", "null"] },
          "semantic_graph": { "type": ["object", "null"] },
          "logs": { "type": ["string", "null"] }
        }
      }
    }
  },

  "x-intents": [
    {
      "trigger": [
        "weekly report",
        "run weekly report",
        "last 7 days report"
      ],
      "action": "runWeeklyReport",
      "x-intent": {
        "x-intent": "weekly",
        "strict": true,
        "description": "ChatGPT must call Cloudflare only; all data-fetching is performed in Railway."
      }
    },
    {
      "trigger": [
        "season report",
        "90 day report",
        "training block report"
      ],
      "action": "runSeasonReport",
      "x-intent": {
        "x-intent": "season",
        "strict": true
      }
    },
    {
      "trigger": [
        "wellness report",
        "recovery report"
      ],
      "action": "runWellnessReport",
      "x-intent": {
        "x-intent": "wellness",
        "strict": true
      }
    },
    {
      "trigger": [
        "summary report",
        "overview"
      ],
      "action": "runSummaryReport",
      "x-intent": {
        "x-intent": "summary",
        "strict": true
      }
    }
  ],

  "x-actions": {
    "runWeeklyReport": {
      "type": "operation",
      "operationId": "runWeeklyReport"
    },
    "runSeasonReport": {
      "type": "operation",
      "operationId": "runSeasonReport"
    },
    "runWellnessReport": {
      "type": "operation",
      "operationId": "runWellnessReport"
    },
    "runSummaryReport": {
      "type": "operation",
      "operationId": "runSummaryReport"
    }
  }
}
