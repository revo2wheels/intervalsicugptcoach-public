{
  "openapi": "3.1.0",
  "info": {
    "title": "Intervals.icu API + Unified Reporting Framework (Hybrid Dual-Mode Schema)",
    "version": "3.9.18-dual-mode",
    "description": "Updated to ensure 7-day full dataset chaining for weekly reports."
  },
  "servers": [
    {
      "url": "https://intervalsicugptcoach.clive-a5a.workers.dev"
    }
  ],
  "x-render-source": {
    "required": "audit_tier2",
    "allow_fallback": false,
    "description": "Renderer must consume validated Tier-2 audit payload only."
  },

  "paths": {
    "/run_report": {
      "get": {
        "summary": "Orchestrated multi-stage report fetch (start → profile → light → wellness → full)",
        "operationId": "runReportStub",
        "x-orchestrated": true,
        "x-chain-source": "#/x-actions/run_report_orchestrated_render",
        "parameters": [
          {
            "name": "reportType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["weekly", "tier0", "season"],
              "default": "weekly"
            },
            "description": "Specifies which report to run: weekly (7-day), tier0 (diagnostic), or season (90-day lightweight)."
          },
          {
            "name": "stage",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["start", "profile", "light", "wellness", "full"],
              "default": "start"
            },
            "description": "Sequential stage of the report orchestration chain."
          }
        ],
        "responses": {
          "200": {
            "description": "Stage-based orchestration response. Each stage returns `next` URL to follow.",
            "x-render": {
              "mode": "sequential",
              "chunk": "auto",
              "auto": true,
              "source": "audit_tier2",
              "title": "Unified Training Report (Staged)"
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "reportType": { "type": "string", "example": "weekly" },
                    "stage": { "type": "string", "example": "profile" },
                    "message": {
                      "type": "string",
                      "example": "Proceed to Tier-0 lightweight (90-day) activities."
                    },
                    "next": {
                      "type": ["string", "null"],
                      "example": "https://intervalsicugptcoach.clive-a5a.workers.dev/run_report?reportType=weekly&stage=light",
                      "description": "Next stage in the chain. Null when orchestration is complete."
                    },
                    "data": {
                      "type": ["object", "null"],
                      "description": "Optional stage payload (e.g., profile, light, wellness, full)."
                    },
                    "context": {
                      "type": "object",
                      "properties": {
                        "report_type": { "type": "string", "example": "weekly" },
                        "range": {
                          "type": "object",
                          "properties": {
                            "lightDays": { "type": "integer", "example": 90 },
                            "wellnessDays": { "type": "integer", "example": 42 },
                            "fullDays": { "type": "integer", "example": 7 }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/athlete/0/activities_t0light": {
      "get": {
        "summary": "List activities (Tier-0 lightweight, 90-day reduced fieldset)",
        "operationId": "listActivitiesLight",
        "parameters": [
          { "name": "oldest", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "newest", "in": "query", "schema": { "type": "string", "format": "date" } },
          {
            "name": "fields",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated field list for lightweight mode"
          }
        ],
        "responses": {
          "200": {
            "description": "Lightweight 90-day dataset",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } }
              }
            }
          }
        }
      }
    },

    "/athlete/0/activities": {
      "get": {
        "summary": "List activities (Tier-0/Tier-1 full, 7-day detailed fields)",
        "operationId": "listActivitiesFull",
        "parameters": [
          { "name": "oldest", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "newest", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer" } },
          { "name": "chunk", "in": "query", "schema": { "type": "string" } },
          { "name": "auto", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Full activity dataset (≤7 days)",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } }
              }
            }
          }
        }
      }
    },

    "/athlete/0/wellness": {
      "get": {
        "summary": "List wellness data (≤42 days, JSON)",
        "operationId": "listWellness",
        "parameters": [
          { "name": "oldest", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "newest", "in": "query", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": {
            "description": "Wellness dataset (up to 42 days)",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Wellness" } }
              }
            }
          }
        }
      }
    },

    "/athlete/0/profile": {
      "get": {
        "summary": "Fetch athlete profile",
        "operationId": "getAthleteProfile",
        "responses": {
          "200": {
            "description": "Athlete profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "athlete": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "name": { "type": "string" },
                        "timezone": { "type": ["string", "null"] },
                        "country": { "type": ["string", "null"] },
                        "sex": { "type": ["string", "null"] }
                      },
                      "required": ["id", "name"]
                    }
                  },
                  "required": ["athlete"]
                }
              }
            }
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "Activity": {
        "type": "object",
        "required": ["id", "start_date_local", "type", "distance", "moving_time"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": ["string", "null"] },
          "type": { "type": "string" },
          "sport_type": { "type": ["string", "null"] },
          "start_date_local": { "type": "string", "format": "date-time" },
          "distance": { "type": "number" },
          "moving_time": { "type": "number" },
          "icu_training_load": { "type": ["number", "null"] },
          "average_heartrate": { "type": ["number", "null"] },
          "IF": { "type": ["number", "null"] },
          "VO2MaxGarmin": { "type": ["number", "null"] }
        }
      },
      "Wellness": {
        "type": "object",
        "required": ["date"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "ctl": { "type": ["number", "null"] },
          "atl": { "type": ["number", "null"] },
          "form": { "type": ["number", "null"] },
          "vo2max": { "type": ["number", "null"] },
          "restingHr": { "type": ["number", "null"] },
          "fatigue": { "type": ["number", "null"] }
        }
      }
    },
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://intervals.icu/oauth/authorize",
            "tokenUrl": "https://intervals.icu/api/oauth/token",
            "scopes": {
              "ACTIVITY:READ": "Read activities",
              "WELLNESS:READ": "Read wellness data",
              "SETTINGS:READ": "Read athlete profile"
            }
          }
        }
      }
    }
  },

  "security": [
    { "OAuth2": ["ACTIVITY:READ", "WELLNESS:READ", "SETTINGS:READ"] }
  ],

  "x-intents": [
    {
      "trigger": [
        "tier0",
        "tier0 pre-audit",
        "run tier0 fetch",
        "run lightweight fetch",
        "prepare 28-day snapshot",
        "fetch 28-day summary",
        "tier0 start"
      ],
      "action": "run_lightweight_audit_pipeline",
      "x-intent": {
        "x-intent": "tier0",
        "enforce_gate": true,
        "allow_partial": false,
        "description": "Locks Tier-0 mode for pre-audit fetches (no render until Tier-1 validation)."
      }
    },
    {
      "trigger": [
        "tier1",
        "fetch activities",
        "run full fetch",
        "tier1 analysis",
        "fetch full dataset"
      ],
      "action": "run_full_audit_pipeline",
      "x-intent": {
        "x-intent": "tier1",
        "enforce_gate": true,
        "allow_partial": false,
        "description": "Locks Tier-1 mode; prevents any lightweight data being rendered directly."
      }
    },
    {
      "trigger": [
        "weekly report",
        "run weekly report",
        "generate weekly report",
        "full weekly report",
        "run 7-day report"
      ],
      "action": "run_report_orchestrated_render",
      "x-intent": {
        "x-intent": "weekly",
        "enforce_gate": true,
        "allow_partial": false,
        "description": "Forces weekly report to use validated Tier-0+Tier-2 pipeline before render."
      }
    },
    {
      "trigger": [
        "season report",
        "run season report",
        "generate season report",
        "run 90 day report",
        "training block report",
        "90 day report",
        "block report"
      ],
      "action": "run_report_orchestrated_render",
      "x-intent": {
        "x-intent": "season",
        "enforce_gate": true,
        "allow_partial": false,
        "description": "Hard-locks 90-day/season report intent and forbids any preRender placeholders or subset previews."
      }
    }
  ],

  "x-actions": {
    "run_report_orchestrated_render": {
      "type": "chain",
      "steps": [
        "getAthleteProfile",
        "listActivitiesLight",
        "listWellness",
        "listActivitiesFull",
        "renderFullWeeklyReport"
      ]
    },
    "listActivitiesLight": {
      "type": "operation",
      "operationId": "listActivitiesLight",
      "args": {
        "oldest": "${today.minusDays(90)}",
        "newest": "${today}"
      }
    },
    "listWellness": {
      "type": "operation",
      "operationId": "listWellness",
      "args": {
        "oldest": "${today.minusDays(42)}",
        "newest": "${today}"
      }
    },
    "listActivitiesFull": {
      "type": "operation",
      "operationId": "listActivitiesFull",
      "args": {
        "oldest": "${today.minusDays(7)}",
        "newest": "${today}",
        "auto": true
      }
    },
    "renderFullWeeklyReport": {
      "type": "render",
      "mode": "report"
    },
    "runReportStub": {
      "$ref": "#/x-actions/run_report_orchestrated_render"
    }
  }
}
